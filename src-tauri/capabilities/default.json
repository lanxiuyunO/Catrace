{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "reminder-popup", "reminder-fullscreen"],
  "permissions": [
    "core:default",
    "opener:default",
    "window-state:default",
    "autostart:default",
    "updater:default",
    "process:default",
    "notification:default",
    "core:window:allow-close"
  ]
}
